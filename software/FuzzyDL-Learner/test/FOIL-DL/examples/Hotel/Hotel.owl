<?xml version="1.0"?>


<!DOCTYPE rdf:RDF [
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
    <!ENTITY Hotel "http://www.semanticweb.org/ontologies/Hotel.owl#" >
]>


<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.w3.org/2002/07/owl"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:Hotel="http://www.semanticweb.org/ontologies/Hotel.owl#">
    <Ontology rdf:about="http://www.semanticweb.org/ontologies/Hotel.owl"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#hasAmenity -->

    <ObjectProperty rdf:about="&Hotel;hasAmenity">
        <rdfs:range rdf:resource="&Hotel;Amenity"/>
        <rdfs:domain rdf:resource="&Hotel;Hotel"/>
        <rdfs:subPropertyOf rdf:resource="&owl;topObjectProperty"/>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#hasDistance -->

    <ObjectProperty rdf:about="&Hotel;hasDistance">
        <rdfs:range rdf:resource="&Hotel;Distance"/>
        <rdfs:domain rdf:resource="&Hotel;Site"/>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#hasRank -->

    <ObjectProperty rdf:about="&Hotel;hasRank">
        <rdfs:domain rdf:resource="&Hotel;Hotel"/>
        <rdfs:range rdf:resource="&Hotel;Rank"/>
    </ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#isDistanceFor -->

    <ObjectProperty rdf:about="&Hotel;isDistanceFor">
        <rdfs:domain rdf:resource="&Hotel;Distance"/>
        <rdfs:range rdf:resource="&Hotel;Site"/>
    </ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#hasPrice -->

    <DatatypeProperty rdf:about="&Hotel;hasPrice">
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&Hotel;Accomodation"/>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#hasValue -->

    <DatatypeProperty rdf:about="&Hotel;hasValue">
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:domain rdf:resource="&Hotel;Distance"/>
        <rdfs:range rdf:resource="&xsd;double"/>
        <rdfs:subPropertyOf rdf:resource="&owl;topDataProperty"/>
    </DatatypeProperty>
    


