    </Class>
    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#Hotel_1_Star -->

    <Class rdf:about="&Hotel;Hotel_1_Star">
        <equivalentClass>
            <Class>
                <intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&Hotel;Hotel"/>
                    <Restriction>
                        <onProperty rdf:resource="&Hotel;hasRank"/>
                        <hasValue rdf:resource="&Hotel;1_Star"/>
                    </Restriction>
                </intersectionOf>
            </Class>
        </equivalentClass>
        <rdfs:subClassOf rdf:resource="&Hotel;Hotel"/>
    </Class>
    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#Hotel_2_Stars -->

    <Class rdf:about="&Hotel;Hotel_2_Stars">
        <equivalentClass>
            <Class>
                <intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="&Hotel;Hotel"/>
                    <Restriction>
                        <onProperty rdf:resource="&Hotel;hasRank"/>
                        <hasValue rdf:resource="&Hotel;2_Stars"/>
                    </Restriction>
                </intersectionOf>
            </Class>
        </equivalentClass>
        <rdfs:subClassOf rdf:resource="&Hotel;Hotel"/>
    </Class>
    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#Hotel_3_Stars -->

    <Class rdf:about="&Hotel;Hotel_3_Stars">
