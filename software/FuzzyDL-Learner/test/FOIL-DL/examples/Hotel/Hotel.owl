        <rdf:type rdf:resource="&Hotel;Rank"/>
    </NamedIndividual>
    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#Hotel_001 -->

    <NamedIndividual rdf:about="&Hotel;Hotel_001">
        <rdf:type rdf:resource="&Hotel;Good_Hotel"/>
        <rdf:type rdf:resource="&Hotel;Hotel"/>
        <rdf:type>
            <Restriction>
                <onProperty rdf:resource="&Hotel;hasAmenity"/>
                <someValuesFrom rdf:resource="&Hotel;Sunbed"/>
            </Restriction>
        </rdf:type>
        <rdf:type>
            <Restriction>
                <onProperty rdf:resource="&Hotel;hasAmenity"/>
                <someValuesFrom rdf:resource="&Hotel;Restaurant"/>
            </Restriction>
        </rdf:type>
        <rdf:type>
            <Restriction>
                <onProperty rdf:resource="&Hotel;hasAmenity"/>
                <someValuesFrom rdf:resource="&Hotel;WI-FI"/>
            </Restriction>
        </rdf:type>
        <rdf:type>
            <Restriction>
                <onProperty rdf:resource="&Hotel;hasAmenity"/>
                <someValuesFrom rdf:resource="&Hotel;24h_Reception"/>
            </Restriction>
        </rdf:type>
        <rdf:type>
            <Restriction>
                <onProperty rdf:resource="&Hotel;hasAmenity"/>
                <someValuesFrom rdf:resource="&Hotel;Bar"/>
            </Restriction>
        </rdf:type>
        <rdf:type>
            <Restriction>
