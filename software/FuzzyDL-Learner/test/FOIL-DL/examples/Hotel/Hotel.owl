    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#1_Star -->

    <NamedIndividual rdf:about="&Hotel;1_Star">
        <rdf:type rdf:resource="&Hotel;Rank"/>
    </NamedIndividual>
    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#2_Stars -->

    <NamedIndividual rdf:about="&Hotel;2_Stars">
        <rdf:type rdf:resource="&Hotel;Rank"/>
    </NamedIndividual>
    


    <!-- http://www.semanticweb.org/ontologies/Hotel.owl#3_Stars -->

    <NamedIndividual rdf:about="&Hotel;3_Stars">
