<?xml version="1.0"?>


<!DOCTYPE rdf:RDF [
    <!ENTITY foo "http://example.com/foo#" >
    <!ENTITY trains "http://example.com/trains#" >
    <!ENTITY trains6 "http://example.com/trains#4" >
    <!ENTITY trains2 "http://example.com/trains#0" >
    <!ENTITY trains3 "http://example.com/trains#3" >
    <!ENTITY trains5 "http://example.com/trains#2" >
    <!ENTITY trains4 "http://example.com/trains#1" >
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY owl2xml "http://www.w3.org/2006/12/owl2-xml#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
]>


<rdf:RDF xmlns="http://example.com/trains#"
     xml:base="http://example.com/trains"
     xmlns:owl2xml="http://www.w3.org/2006/12/owl2-xml#"
     xmlns:foo="http://example.com/foo#"
     xmlns:trains="http://example.com/trains#"
     xmlns:trains6="&trains;4"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:trains5="&trains;2"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:trains3="&trains;3"
     xmlns:trains2="&trains;0"
     xmlns:trains4="&trains;1"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
    <owl:Ontology rdf:about="http://example.com/trains"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.com/trains#hasCar -->

    <owl:ObjectProperty rdf:about="&trains;hasCar">
        <rdfs:range rdf:resource="&trains;Car"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/trains#hasShape -->

    <owl:ObjectProperty rdf:about="&trains;hasShape"/>
    


    <!-- http://example.com/trains#load -->

    <owl:ObjectProperty rdf:about="&trains;load"/>
    


    <!-- http://example.com/trains#loadCount -->

    <owl:ObjectProperty rdf:about="&trains;loadCount"/>
    


    <!-- http://example.com/trains#wheels -->

    <owl:ObjectProperty rdf:about="&trains;wheels"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.com/trains#0LoadCar -->

    <owl:Class rdf:about="&trains;0LoadCar">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&trains;loadCount"/>
                <owl:hasValue rdf:resource="&trains;zero"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="&trains;Car"/>
    </owl:Class>
    


    <!-- http://example.com/trains#1LoadCar -->

    <owl:Class rdf:about="&trains;1LoadCar">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&trains;loadCount"/>
                <owl:hasValue rdf:resource="&trains;one"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="&trains;Car"/>
    </owl:Class>
    


    <!-- http://example.com/trains#2CarTrain -->

    <owl:Class rdf:about="&trains;2CarTrain">
        <rdfs:subClassOf rdf:resource="&trains;Train"/>
    </owl:Class>
    


    <!-- http://example.com/trains#2LoadCar -->

    <owl:Class rdf:about="&trains;2LoadCar">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&trains;loadCount"/>
                <owl:hasValue rdf:resource="&trains;two"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="&trains;Car"/>
    </owl:Class>
    


    <!-- http://example.com/trains#2WheelsCar -->

    <owl:Class rdf:about="&trains;2WheelsCar">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&trains;wheels"/>
                <owl:hasValue rdf:resource="&trains;two"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="&trains;Car"/>
    </owl:Class>
    


    <!-- http://example.com/trains#3CarTrain -->

    <owl:Class rdf:about="&trains;3CarTrain">
        <rdfs:subClassOf rdf:resource="&trains;Train"/>
    </owl:Class>
    


    <!-- http://example.com/trains#3LoadCar -->

    <owl:Class rdf:about="&trains;3LoadCar">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&trains;loadCount"/>
                <owl:hasValue rdf:resource="&trains;three"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="&trains;Car"/>
    </owl:Class>
    


    <!-- http://example.com/trains#3WheelsCar -->

    <owl:Class rdf:about="&trains;3WheelsCar">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&trains;wheels"/>
