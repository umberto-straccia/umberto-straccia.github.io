            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="&trains;Car"/>
    </owl:Class>
    


    <!-- http://example.com/trains#4CarTrain -->

    <owl:Class rdf:about="&trains;4CarTrain">
        <rdfs:subClassOf rdf:resource="&trains;Train"/>
    </owl:Class>
    


    <!-- http://example.com/trains#Car -->

    <owl:Class rdf:about="&trains;Car">
        <rdfs:subClassOf rdf:resource="&owl;Thing"/>
    </owl:Class>
    


    <!-- http://example.com/trains#CircleLoadCar -->

    <owl:Class rdf:about="&trains;CircleLoadCar">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&trains;load"/>
                <owl:hasValue rdf:resource="&trains;circle"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="&trains;Car"/>
    </owl:Class>
    


    <!-- http://example.com/trains#CircleShapeCar -->

    <owl:Class rdf:about="&trains;CircleShapeCar">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="&trains;hasShape"/>
                <owl:hasValue rdf:resource="&trains;circle"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="&trains;Car"/>
    </owl:Class>
    


    <!-- http://example.com/trains#ClosedCar -->

    <owl:Class rdf:about="&trains;ClosedCar">
        <rdfs:subClassOf rdf:resource="&trains;Car"/>
        <owl:disjointWith rdf:resource="&trains;OpenCar"/>
    </owl:Class>
    


    <!-- http://example.com/trains#DoubleCar -->

    <owl:Class rdf:about="&trains;DoubleCar">
        <rdfs:subClassOf rdf:resource="&trains;Car"/>
    </owl:Class>
    


